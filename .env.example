# Copy to .env.local and fill in real values. Real secrets sync through Doppler.

# ── Database ──────────────────────────────────────────────────────────
# Pooled (Supabase PgBouncer, transaction mode) — use in serverless runtime
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct (no pooler) — use for migrations and local Drizzle Studio
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL="https://[PROJECT].supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""

# ── Clerk ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ── Stripe (billing + issuing) ────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_ISSUING_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Plaid ─────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"
PLAID_WEBHOOK_SECRET=""

# ── Inngest ───────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ── Upstash Redis (rate limit + cache) ────────────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Notifications ─────────────────────────────────────────────────────
RESEND_API_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
SLACK_OPS_WEBHOOK_URL=""

# ── AWS (KMS / Secrets / S3 backups / SES backup) ─────────────────────
AWS_REGION="us-east-1"
AWS_KMS_KEY_ID=""
AWS_S3_BACKUP_BUCKET=""

# ── Observability ─────────────────────────────────────────────────────
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
BETTERSTACK_SOURCE_TOKEN=""
