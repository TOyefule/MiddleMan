{
  "name": "middleman",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,sql}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,sql}\"",
    "db:generate": "pnpm --filter @middleman/db generate",
    "db:migrate": "pnpm --filter @middleman/db migrate",
    "db:studio": "pnpm --filter @middleman/db studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "@types/node": "^22.7.5"
  }
}
